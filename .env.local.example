# Firebase Configuration
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_string_here_can_be_generated_with_openssl_rand_base64_32

# Google OAuth Configuration
GOOGLE_ID=your_google_oauth_client_id_here
GOOGLE_SECRET=your_google_oauth_client_secret_here

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rez-portal

# Application Base URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Security tokens for automated payment deadline checks
# Generate secure random tokens for production
# You can use: openssl rand -base64 32
PAYMENT_CHECK_TOKEN=change_this_to_a_secure_random_token_in_production
NEXT_PUBLIC_PAYMENT_CHECK_TOKEN=change_this_to_a_secure_random_token_in_production

# Optional: Custom port for development (default: 3000)
# PORT=3000

# Admin email
ADMIN_EMAIL=admin@yourdomain.com